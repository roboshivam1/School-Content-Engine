{
  "template_id": "festival_greeting",
  "description": "Festival or national holiday greeting post",
  "is_carousel": false,
  "fields": {
    "festival_name": {
      "type": "text",
      "required": true,
      "max_chars": 30,
      "description": "e.g. 'Diwali', 'Independence Day', 'Teachers Day'"
    },
    "greeting_line": {
      "type": "text",
      "required": true,
      "max_chars": 60,
      "description": "Main wish. e.g. 'Wishing you joy, light, and prosperity.'"
    },
    "hindi_greeting": {
      "type": "text",
      "required": false,
      "max_chars": 50,
      "description": "Optional Hindi line. e.g. 'दीपावली की हार्दिक शुभकामनाएं'"
    },
    "year": {
      "type": "text",
      "required": false,
      "max_chars": 6,
      "description": "e.g. '2025'"
    }
  }
}